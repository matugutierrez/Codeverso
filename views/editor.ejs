<!DOCTYPE html>
<html lang="es">
<head>
  <%- include('partials/head', { pageTitle: 'Codear libremente - Codeverso' }) %>
</head>
<body>
  <%- include('partials/nav', { user: user, active: 'codear' }) %>

  <main class="editor-layout">
    <aside class="editor-sidebar">
      <div class="sidebar-section">
        <div class="saved-codes-header" style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:8px">
          <h3 style="margin:0">Mis codigos guardados</h3>
          <button id="btn-delete-all-saved" class="btn-secondary" type="button" title="Borrar todos definitivamente" style="padding:4px 8px;font-size:12px">Borrar todo</button>
        </div>
        <ul id="saved-codes-list" class="saved-codes-list">
          <% savedCodes.forEach(function(c) { %>
          <li data-id="<%= c.id %>" data-lang="<%= c.language_slug %>" class="saved-code-item">
            <span class="saved-code-title"><%= c.title %></span>
            <span class="saved-code-lang"><%= c.language_slug %></span>
            <button class="saved-code-delete" title="Eliminar">&times;</button>
          </li>
          <% }) %>
          <% if (savedCodes.length === 0) { %>
          <li class="saved-codes-empty">Todavia no guardaste ningun codigo.</li>
          <% } %>
        </ul>
      </div>

      <div id="confirm-delete-all-modal" class="cv-modal-overlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:9999;align-items:center;justify-content:center">
        <div class="cv-modal" style="background:#1e1e2e;color:#eee;border:1px solid #333;border-radius:10px;padding:20px 22px;max-width:380px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.5)">
          <h3 style="margin:0 0 10px;font-size:16px">Borrar todos los codigos</h3>
          <p style="margin:0 0 18px;font-size:14px;line-height:1.4;color:#bbb">Seguro que queres borrar definitivamente todos tus codigos guardados? Esta accion no se puede deshacer.</p>
          <div style="display:flex;justify-content:flex-end;gap:8px">
            <button id="btn-cancel-delete-all" type="button" class="btn-secondary">No</button>
            <button id="btn-confirm-delete-all" type="button" class="btn-primary" style="background:#c0392b;border-color:#c0392b">Si, borrar todo</button>
          </div>
        </div>
      </div>
    </aside>

    <section class="editor-main">
      <div class="editor-toolbar">
        <div class="toolbar-group">
          <label for="language-select">Lenguaje</label>
          <div class="lang-dropdown">
            <input id="language-select" class="lang-dropdown-input" placeholder="Buscar lenguaje..." autocomplete="off">
            <div id="language-select-menu" class="lang-dropdown-menu"></div>
          </div>
        </div>
        <div class="toolbar-group toolbar-toggle">
          <label for="indent-help-toggle">Ayuda de indentacion</label>
          <input type="checkbox" id="indent-help-toggle" checked>
        </div>
        <div class="toolbar-group toolbar-toggle">
          <label for="autoclose-toggle">Autocerrar simbolos</label>
          <input type="checkbox" id="autoclose-toggle" checked>
        </div>
        <div class="toolbar-spacer"></div>
        <input type="text" id="code-title" class="code-title-input" placeholder="Titulo del codigo" value="Sin titulo">
        <button id="btn-save" class="btn-secondary">Guardar</button>
        <button id="btn-save-as" class="btn-primary">Guardar como</button>
      </div>

      <div class="editor-info">
        <span id="language-info-chip" class="lang-chip">js</span>
        <span id="language-info-name">JavaScript</span>
        <span id="language-info-detail">indentacion: 2 espacios</span>
      </div>

      <div class="code-editor-wrapper" id="code-editor-wrapper">
        <div class="line-numbers" id="line-numbers">1</div>
        <div class="editor-area">
          <div class="editor-overlay current-line-overlay" id="current-line-overlay"></div>
          <div class="editor-overlay indent-guides-overlay" id="indent-guides-overlay"></div>
          <div class="editor-overlay bracket-match-overlay" id="bracket-match-overlay"></div>
          <pre class="highlight-layer" id="highlight-layer"><code id="highlight-code"></code></pre>
          <textarea id="code-input" class="code-input" spellcheck="false" wrap="off"></textarea>
        </div>
      </div>

      <div class="editor-status" id="editor-status"></div>
    </section>
  </main>

  <script>window.CODEVERSO_DEFAULT_LANG = <%- JSON.stringify(defaultLanguage) %>;</script>
  <script src="/js/highlight.js"></script>
  <script src="/js/lang-dropdown.js"></script>
  <script src="/js/editor-enhancements.js"></script>
  <script src="/js/editor.js"></script>
</body>
</html>
